# Override parent repo's ignore rules: this project genuinely needs data/ tracked.
!data/
!data/**

# Override parent's media-type ignores — gallery videos are site assets here.
!images/**/*.mp4
!images/**/*.webm
!images/**/*.mov
!images/**/*.m4v

# Local build outputs (regenerated by `npm run build`).
images/_generated/
dist/
.wrangler/

# Node deps.
node_modules/
