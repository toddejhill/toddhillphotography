# Override parent repo's ignore rules: this project genuinely needs data/ tracked.
!data/
!data/**

# Override parent's media-type ignores — compressed gallery videos are site assets here.
!images/**/*.mp4
!images/**/*.webm
!images/**/*.mov
!images/**/*.m4v

# Raw video sources are local-only (often hundreds of MB). Build:videos
# compresses *.original.<ext> -> *.mp4; only the compressed output is committed.
images/**/*.original.mp4
images/**/*.original.mov
images/**/*.original.webm
images/**/*.original.m4v

# Local build outputs (regenerated by `npm run build`).
images/_generated/
dist/
.wrangler/

# Node deps.
node_modules/
